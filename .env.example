# Copiar este archivo a .env y completar los valores reales.
# El archivo .env NO debe subirse al repositorio (ya está en .gitignore).

# ── users-api ──────────────────────────────────────────────
USERS_PORT=8080
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=cambia_esto
DB_NAME=users_db
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# ── apartments-api ─────────────────────────────────────────
APARTMENTS_PORT=8081
APARTMENTS_MONGODB_URI=mongodb://root:cambia_esto@mongodb:27017/apartments_db?authSource=admin
APARTMENTS_USERS_API_URL=http://users-api:8080
APARTMENTS_RABBITMQ_URL=amqp://admin:cambia_esto@rabbitmq:5672/

# ── bookings-api ───────────────────────────────────────────
BOOKINGS_PORT=8082
BOOKINGS_MONGODB_URI=mongodb://root:cambia_esto@mongodb:27017/bookings_db?authSource=admin
BOOKINGS_USERS_API_URL=http://users-api:8080
BOOKINGS_APARTMENTS_API_URL=http://apartments-api:8081
BOOKINGS_RABBITMQ_URL=amqp://admin:cambia_esto@rabbitmq:5672/

# ── search-api ─────────────────────────────────────────────
SEARCH_PORT=8083
SEARCH_SOLR_URL=http://solr:8983/solr/apartments
SEARCH_MEMCACHED_URL=memcached:11211
SEARCH_APARTMENTS_API_URL=http://apartments-api:8081
SEARCH_RABBITMQ_URL=amqp://admin:cambia_esto@rabbitmq:5672/

# ── frontend ───────────────────────────────────────────────
VITE_API_BASE_URL=http://search-api:8083
VITE_APARTMENTS_API_URL=http://apartments-api:8081
VITE_BOOKINGS_API_URL=http://bookings-api:8082

# ── infraestructura ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=cambia_esto
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=cambia_esto
